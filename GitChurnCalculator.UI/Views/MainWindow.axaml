<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GitChurnCalculator.UI.Controls"
        xmlns:ScottPlot="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        x:Class="GitChurnCalculator.UI.Views.MainWindow"
        Title="Git Churn Calculator"
        Width="1100"
        Height="720"
        MinWidth="800"
        MinHeight="520">
  <DockPanel>
    <Border DockPanel.Dock="Top"
            Padding="12"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="8">
        <Button Content="Open Repository" Click="OpenRepository_Click" />
        <Button Grid.Column="1" Content="Refresh" Click="Refresh_Click" IsVisible="{Binding HasRepository}" />
        <Button Grid.Column="2" Content="Settings" Click="Settings_Click" />
        <TextBlock Grid.Column="3"
                   VerticalAlignment="Center"
                   Text="{Binding RepositoryPath}"
                   TextTrimming="CharacterEllipsis" />
        <ProgressBar Grid.Column="4"
                     Width="140"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsAnalyzing}" />
      </Grid>
    </Border>

    <Grid>
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="12"
                  IsVisible="{Binding HasNoRepository}">
        <TextBlock Text="No repository selected"
                   HorizontalAlignment="Center"
                   FontSize="18"
                   FontWeight="SemiBold" />
        <Button Content="Open Repository"
                HorizontalAlignment="Center"
                HorizontalContentAlignment="Center"
                Padding="24,12"
                Click="OpenRepository_Click" />
      </StackPanel>

      <TabControl IsVisible="{Binding HasRepository}">
        <TabItem Header="Tree View">
          <Grid ColumnDefinitions="320,*">
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,0,1,0">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="12"
                           Text="Analyzed Files"
                           FontWeight="SemiBold" />
                <TreeView ItemsSource="{Binding FileTree}"
                          SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                  <TreeView.Styles>
                    <Style Selector="TreeViewItem">
                      <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    </Style>
                  </TreeView.Styles>
                  <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                      <TextBlock Text="{Binding Name}" />
                    </TreeDataTemplate>
                  </TreeView.ItemTemplate>
                </TreeView>
              </DockPanel>
            </Border>

            <DockPanel Grid.Column="1">
              <StackPanel DockPanel.Dock="Top" Margin="16,12,16,8">
                <TextBlock Text="File Details" FontWeight="SemiBold" />
                <TextBlock Text="{Binding StatusMessage}" Margin="0,4,0,0" />
                <TextBlock Text="{Binding ErrorMessage}"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
              </StackPanel>

              <DataGrid Margin="16,0,16,16"
                        ItemsSource="{Binding SelectedFileMetrics}"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="False"
                        GridLinesVisibility="All">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Metric" Binding="{Binding Name}" Width="2*" />
                  <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="3*" />
                </DataGrid.Columns>
              </DataGrid>
            </DockPanel>
          </Grid>
        </TabItem>

        <TabItem Header="List View">
          <Grid ColumnDefinitions="320,*">
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,0,1,0">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="12"
                           Text="Analyzed Files"
                           FontWeight="SemiBold" />
                <TreeView ItemsSource="{Binding FileTree}"
                          SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                  <TreeView.Styles>
                    <Style Selector="TreeViewItem">
                      <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    </Style>
                  </TreeView.Styles>
                  <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                      <TextBlock Text="{Binding Name}" />
                    </TreeDataTemplate>
                  </TreeView.ItemTemplate>
                </TreeView>
              </DockPanel>
            </Border>

            <DockPanel Grid.Column="1">
              <StackPanel DockPanel.Dock="Top" Margin="16,12,16,8" Spacing="8">
                <TextBlock Text="Files By Churn Score" FontWeight="SemiBold" />
                <TextBlock Text="{Binding StatusMessage}" />
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                <TextBox Text="{Binding FileNameFilter, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="Filter by file name" />
              </StackPanel>

              <DataGrid Margin="16,0,16,16"
                        ItemsSource="{Binding FileList}"
                        SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="True"
                        GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="File" Binding="{Binding FilePath}" Width="3*" />
                  <DataGridTextColumn Header="Churn Score" Binding="{Binding ChurnRiskScore}" Width="*" />
                  <DataGridTextColumn Header="Commits" Binding="{Binding TotalCommits}" Width="*" />
                  <DataGridTextColumn Header="Authors" Binding="{Binding TotalUniqueAuthors}" Width="*" />
                  <DataGridTextColumn Header="Lines Added" Binding="{Binding LinesAdded}" Width="*" />
                  <DataGridTextColumn Header="Lines Removed" Binding="{Binding LinesRemoved}" Width="*" />
                  <DataGridTextColumn Header="Coverage" Binding="{Binding CoveragePercent}" Width="*" />
                </DataGrid.Columns>
              </DataGrid>
            </DockPanel>
          </Grid>
        </TabItem>

        <TabItem Header="Time series">
          <DockPanel>
            <StackPanel DockPanel.Dock="Top"
                        Margin="16,12,16,8"
                        Orientation="Horizontal"
                        Spacing="12">
              <TextBlock Text="Start"
                         VerticalAlignment="Center" />
              <DatePicker SelectedDate="{Binding TimeSeriesStartDate}" />
              <TextBlock Text="End"
                         VerticalAlignment="Center" />
              <DatePicker SelectedDate="{Binding TimeSeriesEndDate}" />
              <Button Content="Run"
                      Click="RunTimeSeries_Click" />
              <ProgressBar Width="140"
                           IsIndeterminate="True"
                           IsVisible="{Binding IsAnalyzingTimeSeries}" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Top"
                        Margin="16,0,16,8">
              <TextBlock Text="{Binding TimeSeriesStatusMessage}" />
            </StackPanel>

            <Grid Margin="16,0,16,16"
                  ColumnDefinitions="*,320"
                  ColumnSpacing="12">
              <Border Padding="12"
                      BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                      BorderThickness="1">
                <ScottPlot:AvaPlot Name="TimeSeriesPlot"
                                    MinHeight="500" />
              </Border>

              <DockPanel Grid.Column="1">
                <TextBlock DockPanel.Dock="Top"
                           Text="Series"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <DataGrid DockPanel.Dock="Top"
                          Height="220"
                          ItemsSource="{Binding TimeSeries}"
                          SelectedItem="{Binding SelectedTimeSeries, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="File" Binding="{Binding FilePath}" Width="2*" />
                    <DataGridTextColumn Header="Max Score" Binding="{Binding MaxChurnRiskScore}" Width="*" />
                  </DataGrid.Columns>
                </DataGrid>

                <TextBlock DockPanel.Dock="Top"
                           Text="Selected Details"
                           FontWeight="SemiBold"
                           Margin="0,12,0,8" />
                <DataGrid ItemsSource="{Binding SelectedTimeSeriesMetrics}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="False"
                          GridLinesVisibility="All">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Metric" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" />
                  </DataGrid.Columns>
                </DataGrid>
              </DockPanel>
            </Grid>
          </DockPanel>
        </TabItem>

        <TabItem Header="Time Series 2">
          <DockPanel>
            <StackPanel DockPanel.Dock="Top"
                        Margin="16,12,16,8"
                        Orientation="Horizontal"
                        Spacing="12">
              <TextBlock Text="Start"
                         VerticalAlignment="Center" />
              <DatePicker SelectedDate="{Binding TimeSeriesStartDate}" />
              <TextBlock Text="End"
                         VerticalAlignment="Center" />
              <DatePicker SelectedDate="{Binding TimeSeriesEndDate}" />
              <Button Content="Run"
                      Click="RunTimeSeries_Click" />
              <ProgressBar Width="140"
                           IsIndeterminate="True"
                           IsVisible="{Binding IsAnalyzingTimeSeries}" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Top"
                        Margin="16,0,16,8">
              <TextBlock Text="{Binding TimeSeriesStatusMessage}" />
            </StackPanel>

            <Grid Margin="16,0,16,16"
                  ColumnDefinitions="*,320"
                  ColumnSpacing="12">
              <Border Padding="12"
                      BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                      BorderThickness="1">
                <controls:TimeSeriesChart Series="{Binding TimeSeries}"
                                          SelectedSeries="{Binding SelectedTimeSeries, Mode=TwoWay}"
                                          MinHeight="500" />
              </Border>

              <DockPanel Grid.Column="1">
                <TextBlock DockPanel.Dock="Top"
                           Text="Series"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <DataGrid DockPanel.Dock="Top"
                          Height="220"
                          ItemsSource="{Binding TimeSeries}"
                          SelectedItem="{Binding SelectedTimeSeries, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="File" Binding="{Binding FilePath}" Width="2*" />
                    <DataGridTextColumn Header="Max Score" Binding="{Binding MaxChurnRiskScore}" Width="*" />
                  </DataGrid.Columns>
                </DataGrid>

                <TextBlock DockPanel.Dock="Top"
                           Text="Selected Details"
                           FontWeight="SemiBold"
                           Margin="0,12,0,8" />
                <DataGrid ItemsSource="{Binding SelectedTimeSeriesMetrics}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="False"
                          GridLinesVisibility="All">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Metric" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" />
                  </DataGrid.Columns>
                </DataGrid>
              </DockPanel>
            </Grid>
          </DockPanel>
        </TabItem>
      </TabControl>
    </Grid>
  </DockPanel>
</Window>
